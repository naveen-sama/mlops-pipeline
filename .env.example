# ── MLflow ────────────────────────────────────────────────────────────────────
# URI of the MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow experiment name used during training
MLFLOW_EXPERIMENT_NAME=california-housing-xgboost

# ── Model Registry ────────────────────────────────────────────────────────────
# Registered model name in the MLflow Model Registry
MODEL_NAME=MLOpsDemoModel

# Stage to load at serving time (Staging | Production)
MODEL_STAGE=Production

# Pin a specific version instead of using a stage alias (optional)
# MODEL_VERSION=3

# ── AWS S3 artifact storage (optional — required when using S3 artifact store) ─
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for MLflow artifacts (set MLFLOW_DEFAULT_ARTIFACT_ROOT in tracking server)
# MLFLOW_S3_BUCKET=s3://my-mlflow-artifacts

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── Application ───────────────────────────────────────────────────────────────
# Log level for the FastAPI server (debug | info | warning | error)
LOG_LEVEL=info
